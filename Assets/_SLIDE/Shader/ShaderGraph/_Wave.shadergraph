{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "6236a62877924b86a35ca5f7edf519e4",
    "m_Title": "Time",
    "m_Content": "Time: Giá trị thời gian tăng dần liên tục (giây) kể từ khi bắt đầu cảnh. \nDùng cho các hiệu ứng chạy vô tận như cuộn texture (panning).\n\r\nSine Time: Giá trị dao động hình sin từ -1 đến 1. Phù hợp cho hiệu ứng nhấp nháy (pulsating) hoặc đung đưa.\n\r\nCosine Time: Tương tự Sine Time nhưng lệch pha, dao động từ -1 đến 1 theo hàm cos.\n\r\nDelta Time: Khoảng thời gian giữa khung hình trước và khung hình hiện tại.\n\r\nSmooth Delta: Giá trị Delta Time đã được làm mượt để tránh các thay đổi đột ngột.",
    "m_TextSize": 0,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": -1478.6666259765625,
        "y": 365.33331298828127,
        "width": 414.0,
        "height": 236.00003051757813
    },
    "m_Group": {
        "m_Id": ""
    }
}

